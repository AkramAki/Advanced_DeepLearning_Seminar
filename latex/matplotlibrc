# Use PGF backend for LaTeX-compatible plots
backend : pgf

# Figure size in inches (fits nicely into report)
figure.figsize : 5.78, 3.57
figure.constrained_layout.use : True  # avoid overlaps

# Use serif font (matches LaTeX document)
font.family : serif

# Font sizes (consistent with LaTeX body text)
font.size : 11
legend.fontsize : medium
xtick.labelsize : 9
ytick.labelsize : 9

# Do NOT override fonts (use LaTeX fonts instead)
pgf.rcfonts : False

# Enable LaTeX rendering for all text
text.usetex : True
pgf.texsystem : lualatex  # must match your LaTeX setup

# Load your LaTeX style (IMPORTANT: relative path must be correct)
pgf.preamble :

# Trim extra whitespace around figures
savefig.bbox : tight