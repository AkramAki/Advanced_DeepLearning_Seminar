# Use PGF backend for LaTeX-compatible plots
backend : pgf

# Figure size in inches (fits nicely into report)
figure.figsize : 5.78, 3.57
figure.constrained_layout.use : True

# Figure/axes appearance
figure.facecolor : white
axes.facecolor : gainsboro
axes.grid : True
grid.color : white
grid.alpha : 0.3
axes.axisbelow : True
axes.xmargin : 0.005
axes.ymargin : 0.05

# Default line appearance
lines.linewidth : 1.2
axes.prop_cycle : cycler('color', [
    '#4C72B0',  # blue
    '#DD8452',  # orange
    '#55A868',  # green
    '#C44E52',  # red
    '#8172B2',  # purple
    '#937860',  # brown
    '#DA8BC3',  # pink
    '#8C8C8C',  # gray
    '#CCB974',  # olive
    '#64B5CD'   # cyan
])

# Use serif font (matches LaTeX document)
font.family : serif

# Font sizes
font.size : 11
legend.fontsize : medium
xtick.labelsize : 9
ytick.labelsize : 9
axes.labelsize : 11
axes.titlesize : 12

# Do NOT override fonts (use LaTeX fonts instead)
pgf.rcfonts : False

# Enable LaTeX rendering for all text
text.usetex : True
pgf.texsystem : lualatex

# Load your LaTeX style
pgf.preamble :

# Trim extra whitespace around figures
savefig.bbox : tight